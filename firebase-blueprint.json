{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the inventory.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "costPrice": { "type": "number", "description": "Cost to the business for profit calculation" },
        "stock": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["name", "price", "costPrice", "stock", "userId"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A regular customer.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "userId", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A customer invoice.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string", "description": "Optional for custom items" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "costPrice": { "type": "number" },
              "isCustom": { "type": "boolean" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "totalCost": { "type": "number" },
        "profit": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "items", "totalAmount", "totalCost", "profit", "date", "userId", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expenses.",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["description", "amount", "date", "userId", "createdAt"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Inventory products" },
    "customers": { "schema": "Customer", "description": "Regular customers" },
    "invoices": { "schema": "Invoice", "description": "Customer invoices" },
    "expenses": { "schema": "Expense", "description": "Business expenses" }
  }
}
